<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Manage Orders - PS HUB Admin</title>
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css">
    <link rel="stylesheet" href="Project.css">
</head>
<body class="bg-light">

    <div class="container my-5">
        <div class="d-flex justify-content-between align-items-center mb-4">
            <h2>All Orders (Admin)</h2>
            <a href="/" class="btn btn-secondary">&larr; Back to Games</a>
        </div>

        <% if (orders.length === 0) { %>
            <p class="text-muted">No orders have been placed yet.</p>
        <% } else { %>
            <table class="table table-bordered bg-white align-middle">
                <thead class="table-dark">
                    <tr>
                        <th>Game</th>
                        <th>Buyer Name</th>
                        <th>Phone</th>
                        <th>Delivery Address</th>
                        <th>Ordered On</th>
                        <th>Status</th>
                        <th>Action</th>
                    </tr>
                </thead>
                <tbody>
                    <% orders.forEach(function(order) { %>
                        <tr>
                            <td><%= order.gameName %></td>
                            <td><%= order.buyerName %></td>
                            <td><%= order.phone %></td>
                            <td><%= order.address %></td>
                            <td><%= order.orderedAt %></td>
                            <td>
                                <span class="badge <%= order.status === 'Delivered' ? 'bg-success' : 'bg-warning text-dark' %>">
                                    <%= order.status %>
                                </span>
                            </td>
                            <td>
                                <% if (order.status !== "Delivered") { %>
                                    <form method="POST" action="/admin/orders/<%= order.id %>/deliver">
                                        <button type="submit" class="btn btn-sm btn-success">Mark Delivered</button>
                                    </form>
                                <% } %>
                            </td>
                        </tr>
                    <% }); %>
                </tbody>
            </table>
        <% } %>
    </div>

</body>
</html>
